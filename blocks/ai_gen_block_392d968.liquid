{% doc %}
  @prompt
    I need a section that will play videos from youtube using either the link or video id. the section should have the ability to turn on or off autoplay, sound, and full-width or not. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign video_id = ''
  
  if block.settings.youtube_url contains 'youtube.com/watch?v='
    assign video_id = block.settings.youtube_url | split: 'v=' | last | split: '&' | first
  elsif block.settings.youtube_url contains 'youtu.be/'
    assign video_id = block.settings.youtube_url | split: 'youtu.be/' | last | split: '?' | first
  elsif block.settings.youtube_url contains 'youtube.com/embed/'
    assign video_id = block.settings.youtube_url | split: 'embed/' | last | split: '?' | first
  else
    assign video_id = block.settings.youtube_url
  endif

  assign autoplay_param = 0
  if block.settings.enable_autoplay
    assign autoplay_param = 1
  endif

  assign mute_param = 0
  if block.settings.enable_mute
    assign mute_param = 1
  endif

  assign container_width = '100%'
  if block.settings.enable_full_width == false
    assign container_width = block.settings.desktop_width_percent | append: '%'
  endif
%}

{% style %}
  .ai-youtube-video-container-{{ ai_gen_id }} {
    display: block;
    width: {{ container_width }};
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_left_right }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_left_right }}px;
  }

  .ai-youtube-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-youtube-video-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    color: #666;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-youtube-video-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<youtube-video-{{ ai_gen_id }}
  class="ai-youtube-video-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-youtube-video-wrapper-{{ ai_gen_id }}">
    {% if video_id != blank %}
      <iframe
        class="ai-youtube-video-iframe-{{ ai_gen_id }}"
        src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ autoplay_param }}&mute={{ mute_param }}&controls={{ block.settings.show_controls | default: 1 }}&rel=0&modestbranding=1"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        title="YouTube video player"
      ></iframe>
    {% else %}
      <div class="ai-youtube-video-placeholder-{{ ai_gen_id }}">
        Add a YouTube video URL or video ID in the block settings
      </div>
    {% endif %}
  </div>
</youtube-video-{{ ai_gen_id }}>

<script>
  (function() {
    class YoutubeVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const iframe = this.querySelector('.ai-youtube-video-iframe-{{ ai_gen_id }}');
        if (iframe) {
          iframe.addEventListener('load', function() {
            console.log('YouTube video loaded');
          });
        }
      }
    }

    customElements.define('youtube-video-{{ ai_gen_id }}', YoutubeVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "YouTube video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL or video ID",
      "info": "Paste full YouTube URL or just the video ID"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25",
          "label": "16:9"
        },
        {
          "value": "75",
          "label": "4:3"
        },
        {
          "value": "100",
          "label": "1:1"
        },
        {
          "value": "177.78",
          "label": "9:16"
        }
      ],
      "default": "56.25"
    },
    {
      "type": "header",
      "content": "Playback"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": false,
      "info": "Video will autoplay when page loads"
    },
    {
      "type": "checkbox",
      "id": "enable_mute",
      "label": "Mute video",
      "default": false,
      "info": "Start video with sound muted"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "Enable full width",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100,
      "info": "Only applies when full width is disabled"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left_right",
      "label": "Padding left and right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}