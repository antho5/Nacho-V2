{% doc %}
  @prompt
    Create a section that will play youtube videos. The section should have the options to link directly to the video on youtube, autoplay the video, as well as mute the video.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-youtube-video-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-youtube-video__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-youtube-video__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-youtube-video__iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-video__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-youtube-video__placeholder-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .ai-youtube-video__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-youtube-video__link-wrapper-{{ ai_gen_id }} {
    margin-top: 20px;
    text-align: center;
  }

  .ai-youtube-video__link-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background-color: {{ block.settings.link_button_bg }};
    color: {{ block.settings.link_button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.link_button_radius }}px;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-youtube-video__link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.link_button_bg_hover }};
  }

  .ai-youtube-video__link-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-youtube-video-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<youtube-video-{{ ai_gen_id }}
  class="ai-youtube-video-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-youtube-video__container-{{ ai_gen_id }}">
    <div class="ai-youtube-video__wrapper-{{ ai_gen_id }}">
      {% if block.settings.video_url != blank %}
        <iframe
          class="ai-youtube-video__iframe-{{ ai_gen_id }}"
          src="https://www.youtube.com/embed/{{ block.settings.video_url }}?{% if block.settings.autoplay %}autoplay=1&{% endif %}{% if block.settings.mute %}mute=1&{% endif %}rel=0&modestbranding=1"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      {% else %}
        <div class="ai-youtube-video__placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <div class="ai-youtube-video__empty-state-{{ ai_gen_id }}">
            Next, add a YouTube video ID
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_link and block.settings.video_url != blank %}
      <div class="ai-youtube-video__link-wrapper-{{ ai_gen_id }}">
        <a
          href="https://www.youtube.com/watch?v={{ block.settings.video_url }}"
          class="ai-youtube-video__link-{{ ai_gen_id }}"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          {{ block.settings.link_text }}
        </a>
      </div>
    {% endif %}
  </div>
</youtube-video-{{ ai_gen_id }}>

<script>
  (function() {
    class YouTubeVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const iframe = this.querySelector('.ai-youtube-video__iframe-{{ ai_gen_id }}');
        if (iframe) {
          iframe.addEventListener('load', function() {
            console.log('YouTube video loaded');
          });
        }
      }
    }

    customElements.define('youtube-video-{{ ai_gen_id }}', YouTubeVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "YouTube video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube video ID",
      "info": "Enter the video ID from the YouTube URL (e.g., 'dQw4w9WgXcQ' from youtube.com/watch?v=dQw4w9WgXcQ)"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": false,
      "info": "Video will play automatically when the page loads"
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute video",
      "default": false,
      "info": "Video will be muted by default"
    },
    {
      "type": "header",
      "content": "Link to YouTube"
    },
    {
      "type": "checkbox",
      "id": "show_link",
      "label": "Show link to YouTube",
      "default": true
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Watch on YouTube"
    },
    {
      "type": "color",
      "id": "link_button_bg",
      "label": "Button background",
      "default": "#FF0000"
    },
    {
      "type": "color",
      "id": "link_button_bg_hover",
      "label": "Button background hover",
      "default": "#CC0000"
    },
    {
      "type": "color",
      "id": "link_button_text",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "link_button_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Video border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}
