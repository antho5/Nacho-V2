{% doc %}
  @prompt
    Create a section that will play youtube videos. The section should have the options to link directly to the video on youtube, autoplay the video, as well as mute the video and make the section full width. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  assign video_url = block.settings.youtube_url
  assign video_id = ''
  
  if video_url contains 'youtube.com/watch?v='
    assign video_id = video_url | split: 'v=' | last | split: '&' | first
  elsif video_url contains 'youtu.be/'
    assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
  elsif video_url contains 'youtube.com/embed/'
    assign video_id = video_url | split: 'embed/' | last | split: '?' | first
  endif

  assign autoplay_param = ''
  if block.settings.autoplay
    assign autoplay_param = '&autoplay=1'
  endif

  assign mute_param = ''
  if block.settings.mute
    assign mute_param = '&mute=1'
  endif

  assign loop_param = ''
  if block.settings.loop
    assign loop_param = '&loop=1&playlist=' | append: video_id
  endif

  assign controls_param = '&controls=1'
  if block.settings.hide_controls
    assign controls_param = '&controls=0'
  endif
%}

{% style %}
  .ai-youtube-video-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-youtube-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-youtube-video-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-youtube-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    color: #666;
    text-align: center;
    padding: 20px;
  }

  .ai-youtube-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .ai-youtube-video-placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    max-width: 300px;
  }

  {% if block.settings.show_link_button and video_id != blank %}
    .ai-youtube-video-link-wrapper-{{ ai_gen_id }} {
      margin-top: {{ block.settings.button_spacing }}px;
      text-align: {{ block.settings.button_alignment }};
    }

    .ai-youtube-video-link-{{ ai_gen_id }} {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 24px;
      background-color: {{ block.settings.button_bg_color }};
      color: {{ block.settings.button_text_color }};
      text-decoration: none;
      border-radius: {{ block.settings.button_border_radius }}px;
      font-size: {{ block.settings.button_font_size }}px;
      font-weight: 600;
      transition: background-color 0.3s ease;
    }

    .ai-youtube-video-link-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.button_hover_bg_color }};
      color: {{ block.settings.button_hover_text_color }};
    }

    .ai-youtube-video-link-icon-{{ ai_gen_id }} {
      width: 16px;
      height: 16px;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-youtube-video-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<youtube-video-{{ ai_gen_id }}
  class="ai-youtube-video-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-youtube-video-wrapper-{{ ai_gen_id }}">
    {% if video_id != blank %}
      <iframe
        class="ai-youtube-video-iframe-{{ ai_gen_id }}"
        src="https://www.youtube.com/embed/{{ video_id }}?rel=0{{ autoplay_param }}{{ mute_param }}{{ loop_param }}{{ controls_param }}"
        title="{{ block.settings.video_title | escape }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    {% else %}
      <div class="ai-youtube-video-placeholder-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        <div class="ai-youtube-video-placeholder-text-{{ ai_gen_id }}">
          Next, add a YouTube video URL
        </div>
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_link_button and video_id != blank %}
    <div class="ai-youtube-video-link-wrapper-{{ ai_gen_id }}">
      <a
        href="https://www.youtube.com/watch?v={{ video_id }}"
        target="_blank"
        rel="noopener noreferrer"
        class="ai-youtube-video-link-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
        <svg class="ai-youtube-video-link-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
      </a>
    </div>
  {% endif %}
</youtube-video-{{ ai_gen_id }}>

<script>
  (function() {
    class YoutubeVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('youtube-video-{{ ai_gen_id }}', YoutubeVideo{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "YouTube video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL",
      "info": "Paste any YouTube video URL (e.g., https://www.youtube.com/watch?v=VIDEO_ID)"
    },
    {
      "type": "text",
      "id": "video_title",
      "label": "Video title",
      "default": "YouTube video",
      "info": "Used for accessibility"
    },
    {
      "type": "header",
      "content": "Playback settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": false,
      "info": "Video will play automatically when loaded. Most browsers require mute to be enabled for autoplay."
    },
    {
      "type": "checkbox",
      "id": "mute",
      "label": "Mute video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "hide_controls",
      "label": "Hide video controls",
      "default": false
    },
    {
      "type": "header",
      "content": "Link button"
    },
    {
      "type": "checkbox",
      "id": "show_link_button",
      "label": "Show link to YouTube",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Watch on YouTube"
    },
    {
      "type": "select",
      "id": "button_alignment",
      "label": "Button alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_spacing",
      "label": "Button spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#FF0000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#CC0000"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button hover text",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Video border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "YouTube video"
    }
  ]
}
{% endschema %}
