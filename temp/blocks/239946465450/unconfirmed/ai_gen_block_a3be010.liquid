{% doc %}
  @prompt
    I need to create a section that will connect to our variant metafield custom.variant_description
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-description-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-variant-description__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-variant-description__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-variant-description__content-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-variant-description__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-variant-description__empty-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    font-style: italic;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-variant-description-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-variant-description__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-variant-description__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<variant-description-{{ ai_gen_id }}
  class="ai-variant-description-{{ ai_gen_id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.show_heading and block.settings.heading != blank %}
    <h3 class="ai-variant-description__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h3>
  {% endif %}

  <div
    class="ai-variant-description__content-{{ ai_gen_id }}"
    data-variant-description
  >
    {% if product.selected_or_first_available_variant.metafields.custom.variant_description != blank %}
      {{ product.selected_or_first_available_variant.metafields.custom.variant_description }}
    {% else %}
      <div class="ai-variant-description__empty-{{ ai_gen_id }}">
        {{ block.settings.empty_state_text }}
      </div>
    {% endif %}
  </div>
</variant-description-{{ ai_gen_id }}>

<script>
  (function() {
    class VariantDescription{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.contentElement = this.querySelector('[data-variant-description]');
      }

      connectedCallback() {
        this.setupVariantListener();
      }

      setupVariantListener() {
        const productForm = document.querySelector('product-form');
        if (!productForm) return;

        productForm.addEventListener('variant-change', (event) => {
          const variant = event.detail.variant;
          this.updateDescription(variant);
        });
      }

      updateDescription(variant) {
        if (!variant) return;

        const variantDescription = variant.metafields?.custom?.variant_description;
        const emptyStateText = '{{ block.settings.empty_state_text | escape }}';

        if (variantDescription) {
          this.contentElement.innerHTML = variantDescription;
          this.contentElement.classList.remove('ai-variant-description__empty-{{ ai_gen_id }}');
        } else {
          this.contentElement.innerHTML = `<div class="ai-variant-description__empty-{{ ai_gen_id }}">${emptyStateText}</div>`;
        }
      }
    }

    customElements.define('variant-description-{{ ai_gen_id }}', VariantDescription{{ ai_gen_id }});
  })();
</script>

