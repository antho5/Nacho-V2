{% doc %}
  @prompt
    I want to create a section that can have multiple videos added from youtube links in a slideshow manner. 
    
    , Video links should be able to be added from youtube or shopify cdn
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-video-slideshow__header-{{ ai_gen_id }} {
    padding: {{ block.settings.header_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    background-color: {{ block.settings.header_background_color }};
  }

  .ai-video-slideshow__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    line-height: 1.2;
  }

  .ai-video-slideshow__description-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.4;
  }

  .ai-video-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.video_height }}px;
    overflow: hidden;
  }

  .ai-video-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-video-slideshow__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }

  .ai-video-slideshow__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #666;
    text-align: center;
    padding: 20px;
  }

  .ai-video-slideshow__placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  .ai-video-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.control_background_color }};
    border: none;
    border-radius: 50%;
    width: {{ block.settings.control_size }}px;
    height: {{ block.settings.control_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
    color: {{ block.settings.control_color }};
  }

  .ai-video-slideshow__controls-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.control_hover_background_color }};
    color: {{ block.settings.control_hover_color }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-video-slideshow__prev-{{ ai_gen_id }} {
    left: {{ block.settings.control_offset }}px;
  }

  .ai-video-slideshow__next-{{ ai_gen_id }} {
    right: {{ block.settings.control_offset }}px;
  }

  .ai-video-slideshow__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.dot_spacing }}px;
    padding: {{ block.settings.dots_padding }}px;
    background-color: {{ block.settings.dots_background_color }};
  }

  .ai-video-slideshow__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-video-slideshow__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-video-slideshow__dot-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.dot_hover_color }};
  }

  .ai-video-slideshow__video-title-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: white;
    padding: 20px;
    font-size: {{ block.settings.video_title_font_size }}px;
    font-weight: {{ block.settings.video_title_font_weight }};
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-video-slideshow__slide-{{ ai_gen_id }}.active .ai-video-slideshow__video-title-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-video-slideshow__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: rgba(0, 0, 0, 0.7);
    border: none;
    border-radius: 50%;
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 3;
    color: white;
  }

  .ai-video-slideshow__play-button-{{ ai_gen_id }}:hover {
    background-color: rgba(0, 0, 0, 0.9);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-slideshow__play-button-{{ ai_gen_id }}.hidden {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .ai-video-slideshow__container-{{ ai_gen_id }} {
      height: {{ block.settings.video_height | times: 0.7 }}px;
    }

    .ai-video-slideshow__controls-{{ ai_gen_id }} {
      width: {{ block.settings.control_size | times: 0.8 }}px;
      height: {{ block.settings.control_size | times: 0.8 }}px;
    }

    .ai-video-slideshow__prev-{{ ai_gen_id }} {
      left: {{ block.settings.control_offset | times: 0.5 }}px;
    }

    .ai-video-slideshow__next-{{ ai_gen_id }} {
      right: {{ block.settings.control_offset | times: 0.5 }}px;
    }

    .ai-video-slideshow__play-button-{{ ai_gen_id }} {
      width: 60px;
      height: 60px;
    }
  }
{% endstyle %}

<video-slideshow-{{ ai_gen_id }}
  class="ai-video-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-delay="{{ block.settings.autoplay_delay }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank or block.settings.description != blank %}
    <div class="ai-video-slideshow__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-video-slideshow__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-video-slideshow__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-video-slideshow__container-{{ ai_gen_id }}">
    {% assign has_videos = false %}
    {% for i in (1..5) %}
      {% liquid
        assign video_url_key = 'video_url_' | append: i
        assign video_file_key = 'video_file_' | append: i
        assign video_title_key = 'video_title_' | append: i
        assign video_url = block.settings[video_url_key]
        assign video_file = block.settings[video_file_key]
        assign video_title = block.settings[video_title_key]
      %}
      
      {% if video_url != blank or video_file != blank %}
        {% assign has_videos = true %}
        
        <div class="ai-video-slideshow__slide-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}">
          {% if video_url != blank %}
            {% assign video_id = video_url | split: 'v=' | last | split: '&' | first %}
            {% if video_id == video_url %}
              {% assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first %}
            {% endif %}
            
            <iframe
              class="ai-video-slideshow__video-{{ ai_gen_id }}"
              src="https://www.youtube.com/embed/{{ video_id }}?rel=0&modestbranding=1"
              title="{{ video_title | default: 'YouTube video' | escape }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          {% elsif video_file != blank %}
            <video
              class="ai-video-slideshow__video-{{ ai_gen_id }}"
              controls
              preload="metadata"
              {% if block.settings.video_muted %}muted{% endif %}
              {% if block.settings.video_loop %}loop{% endif %}
            >
              <source src="{{ video_file }}" type="video/mp4">
              Your browser does not support the video tag.
            </video>
            {% if block.settings.show_play_button %}
              <button class="ai-video-slideshow__play-button-{{ ai_gen_id }}" data-video-index="{{ forloop.index0 }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </button>
            {% endif %}
          {% endif %}
          
          {% if video_title != blank and block.settings.show_video_titles %}
            <div class="ai-video-slideshow__video-title-{{ ai_gen_id }}">{{ video_title }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {% unless has_videos %}
      <div class="ai-video-slideshow__slide-{{ ai_gen_id }} active">
        <div class="ai-video-slideshow__placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <p>Add YouTube URLs or upload video files to get started</p>
        </div>
      </div>
    {% endunless %}

    {% if has_videos and block.settings.show_navigation %}
      <button class="ai-video-slideshow__controls-{{ ai_gen_id }} ai-video-slideshow__prev-{{ ai_gen_id }}" aria-label="Previous video">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15,18 9,12 15,6"></polyline>
        </svg>
      </button>
      <button class="ai-video-slideshow__controls-{{ ai_gen_id }} ai-video-slideshow__next-{{ ai_gen_id }}" aria-label="Next video">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
    {% endif %}
  </div>

  {% if has_videos and block.settings.show_dots %}
    <div class="ai-video-slideshow__dots-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign video_url_key = 'video_url_' | append: i
          assign video_file_key = 'video_file_' | append: i
          assign video_url = block.settings[video_url_key]
          assign video_file = block.settings[video_file_key]
        %}
        {% if video_url != blank or video_file != blank %}
          <button class="ai-video-slideshow__dot-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Go to video {{ forloop.index }}"></button>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</video-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayTimer = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-video-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-video-slideshow__dot-{{ ai_gen_id }}'));
        this.prevBtn = this.querySelector('.ai-video-slideshow__prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-video-slideshow__next-{{ ai_gen_id }}');
        this.playButtons = Array.from(this.querySelectorAll('.ai-video-slideshow__play-button-{{ ai_gen_id }}'));
        
        this.setupEventListeners();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.previousSlide());
        }
        
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.playButtons.forEach((button, index) => {
          button.addEventListener('click', () => this.playVideo(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());

        this.slides.forEach((slide, index) => {
          const video = slide.querySelector('video');
          if (video) {
            video.addEventListener('play', () => {
              this.stopAutoplay();
              this.hidePlayButton(index);
            });
            video.addEventListener('pause', () => {
              this.showPlayButton(index);
              this.startAutoplay();
            });
            video.addEventListener('ended', () => {
              this.showPlayButton(index);
              this.startAutoplay();
            });
          }
        });
      }

      playVideo(index) {
        const slide = this.slides[index];
        const video = slide.querySelector('video');
        if (video) {
          video.play();
        }
      }

      hidePlayButton(index) {
        const playButton = this.playButtons[index];
        if (playButton) {
          playButton.classList.add('hidden');
        }
      }

      showPlayButton(index) {
        const playButton = this.playButtons[index];
        if (playButton) {
          playButton.classList.remove('hidden');
        }
      }

      pauseAllVideos() {
        this.slides.forEach((slide) => {
          const video = slide.querySelector('video');
          if (video && !video.paused) {
            video.pause();
          }
        });
      }

      goToSlide(index) {
        if (index < 0 || index >= this.slides.length) return;

        this.pauseAllVideos();

        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const autoplay = this.dataset.autoplay === 'true';
        const delay = parseInt(this.dataset.autoplayDelay) * 1000;
        
        if (autoplay && this.slides.length > 1) {
          this.autoplayTimer = setInterval(() => {
            const currentSlide = this.slides[this.currentSlide];
            const video = currentSlide.querySelector('video');
            
            if (!video || video.paused) {
              this.nextSlide();
            }
          }, delay);
        }
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }
    }

    customElements.define('video-slideshow-{{ ai_gen_id }}', VideoSlideshow{{ ai_gen_id }});
  })();
</script>

